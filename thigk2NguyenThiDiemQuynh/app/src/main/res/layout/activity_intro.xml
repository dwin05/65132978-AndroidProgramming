<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/galaxy_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:background="@drawable/bg_cong"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="350dp"
            android:layout_height="82dp"
            android:layout_gravity="center"
            android:paddingStart="20dp"
            android:paddingTop="30dp"
            android:text="HELLO, HAVE A NICE DAY!"
            android:textColor="#4B0606"
            android:textSize="25dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="335dp"
        android:layout_height="81dp"
        android:layout_marginTop="164dp"
        android:gravity="center"
        android:text="Bài làm môn Lập trình thiết bị di động"
        android:textAllCaps="true"
        android:textColor="#061250"

        android:textSize="26sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgAvatar"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/avata"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:srcCompat="@drawable/avata_tron" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Họ tên: Nguyễn Thị Diễm Quỳnh"
        android:textSize="24sp"
        android:textColor="#3E0B0B"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgAvatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Lớp -->
    <TextView
        android:id="@+id/tvClass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lớp: 65.CNTT-2"
        android:textSize="24sp"
        android:textColor="#3E0B0B"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- MSSV -->
    <TextView
        android:id="@+id/tvMSSV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MSSV: 65132978"
        android:textSize="24sp"
        android:textColor="#3E0B0B"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvClass"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnIntro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Quay lại"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvMSSV" />

</androidx.constraintlayout.widget.ConstraintLayout>