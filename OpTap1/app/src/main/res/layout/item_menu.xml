<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="80dp">

    <ImageView
        android:id="@+id/imgMonAn"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="#BBB4F2"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#ECFAC4"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="5dp">

        <TextView
            android:id="@+id/tvTen"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:layout_gravity="center"
            android:text="Ca vien chien mam toi"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/tvGia"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text="50.000 VND" />

        <TextView
            android:id="@+id/tvMoTa"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text="Ca vien chien du loai, rau muong xao voi mam toi" />
    </LinearLayout>
</LinearLayout>