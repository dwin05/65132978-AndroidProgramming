<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/imgchinh"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:layout_margin="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/nen" />

    <ImageView
        android:id="@+id/imageView5"
        android:layout_width="213dp"
        android:layout_height="569dp"
        android:layout_margin="5dp"
        android:background="@drawable/imgchinh"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView4"
        app:srcCompat="@drawable/images" />

    <Button
        android:id="@+id/btnBMI"
        android:layout_width="132dp"
        android:layout_height="56dp"
        android:layout_marginStart="253dp"
        android:layout_marginTop="62dp"
        android:layout_marginEnd="26dp"
        android:text="BMI"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView4" />

    <Button
        android:id="@+id/btnMonAn"
        android:layout_width="132dp"
        android:layout_height="56dp"
        android:layout_marginTop="71dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="60dp"
        android:text="Mon an"
        app:layout_constraintBottom_toTopOf="@+id/btnBaiThuoc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBMI"
        app:layout_constraintVertical_bias="0.75" />

    <Button
        android:id="@+id/btnBaiThuoc"
        android:layout_width="132dp"
        android:layout_height="56dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="60dp"
        android:text="Bai thuoc"
        app:layout_constraintBottom_toTopOf="@+id/btnIntro"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnIntro"
        android:layout_width="132dp"
        android:layout_height="56dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="120dp"
        android:text="Gioi thieu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnBonus"
        android:layout_width="146dp"
        android:layout_height="67dp"
        android:layout_marginStart="153dp"
        android:layout_marginTop="492dp"
        android:layout_marginEnd="20dp"
        android:text="Bai lam them"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView4" />

</androidx.constraintlayout.widget.ConstraintLayout>